__pycache__/
.pytest_cache/
*.py[cod]
*.egg-info/
.tmp/
.paper_work/
.claude/

# Experiment payloads stay local/data-release scoped, but the lightweight
# ledger and registered-plan metadata are versioned for auditability.
outputs/*
!outputs/EXPERIMENT_REGISTRY.json
!outputs/EXPERIMENT_ARTIFACT_INDEX.jsonl
!outputs/exposure_matched_direct_u_v2_conditioning/
outputs/exposure_matched_direct_u_v2_conditioning/*
!outputs/exposure_matched_direct_u_v2_conditioning/experiment_plan.json
!outputs/exposure_matched_direct_u_v2_conditioning/experiment_status_history.jsonl
data/raw/*
!data/raw/gmtnet/
data/raw/gmtnet/*
!data/raw/gmtnet/SOURCE_COMMIT.txt
data/processed/pbc_graph_cache/
# Regenerable binary caches derived from public JARVIS/GMTNet inputs. Keep
# manifests and explicit split JSON files versioned; publish large cache
# snapshots through a data release rather than normal Git history.
data/processed/**/*.pt
data/processed/jarvis_raw_index/
data/processed/piezo_symmetry_targets*/
